
# Slack incoming webhook for failure alerts (B2/B3)
SLACK_WEBHOOK_URL=

# Telegram MTProto client (api_id/api_hash from https://my.telegram.org).
# TELEGRAM_SESSION is generated once via `npx tsx src/cli/telegram-login.ts`
# — treat it as a long-lived credential, never commit or log it.
TG_API_ID=
TG_API_HASH=
TELEGRAM_SESSION=
